{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "license", "models", "status", "notes"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "title": { "type": "string" },
          "license": { "type": "string" },
          "models": { "type": "array", "items": { "enum": ["x68000", "xvi", "x68030"] } },
          "status": { "enum": ["pass", "partial", "fail", "untested"] },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
