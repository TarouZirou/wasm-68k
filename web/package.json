{
  "name": "wasm-68k-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build ../crates/x68k-wasm --target web --out-dir ../../web/src/wasm",
    "dev": "npm run build:wasm && vite",
    "dev:vite": "vite",
    "typecheck": "tsc --noEmit",
    "build": "npm run build:wasm && npm run typecheck && vite build",
    "build:pages": "GITHUB_PAGES=true npm run build",
    "preview": "vite preview",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@types/node": "^26.1.1",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
}
